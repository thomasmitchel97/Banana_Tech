        // Generar circuitos de fondo
        function createCircuits() {
            const bg = document.getElementById('circuitBg');
            const circuitCount = 30;

            for (let i = 0; i < circuitCount; i++) {
                // Líneas horizontales
                const hLine = document.createElement('div');
                hLine.className = 'circuit-line horizontal';
                hLine.style.left = Math.random() * 100 + '%';
                hLine.style.top = Math.random() * 100 + '%';
                hLine.style.animationDelay = Math.random() * 2 + 's';
                bg.appendChild(hLine);

                // Líneas verticales
                const vLine = document.createElement('div');
                vLine.className = 'circuit-line vertical';
                vLine.style.left = Math.random() * 100 + '%';
                vLine.style.top = Math.random() * 100 + '%';
                vLine.style.animationDelay = Math.random() * 2 + 's';
                bg.appendChild(vLine);

                // Nodos
                const node = document.createElement('div');
                node.className = 'circuit-node';
                node.style.left = Math.random() * 100 + '%';
                node.style.top = Math.random() * 100 + '%';
                node.style.animationDelay = Math.random() * 1.5 + 's';
                bg.appendChild(node);
            }
        }

        // Generar partículas flotantes
        function createParticles() {
            const particles = document.getElementById('particles');
            
            setInterval(() => {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDelay = '0s';
                particle.style.animationDuration = (Math.random() * 3 + 5) + 's';
                particles.appendChild(particle);

                // Remover partícula después de la animación
                setTimeout(() => {
                    if (particle.parentNode) {
                        particle.parentNode.removeChild(particle);
                    }
                }, 8000);
            }, 500);
        }

        // Efectos de hover para los botones
        document.querySelectorAll('.btn').forEach(btn => {
            btn.addEventListener('mouseenter', function() {
                this.style.textShadow = '0 0 10px currentColor';
            });
            
            btn.addEventListener('mouseleave', function() {
                this.style.textShadow = 'none';
            });
        });

        // Inicializar efectos
        function isMobile() {
            return /Mobi|Android|iPhone|iPad|iPod|Opera Mini|IEMobile|WPDesktop/i.test(navigator.userAgent);
        }

        document.addEventListener('DOMContentLoaded', function() {
            if (!isMobile()) {
                createCircuits();
                createParticles();
            }
        });

